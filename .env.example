# Copy to .env and fill in. App runs in dev mode with empty values.

# Site
APP_BASE_URL=http://localhost:8000
APP_SECRET=change-me-to-a-long-random-string

# Stripe (TEST mode keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# Email (optional in dev — magic links print to console if blank)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=hello@financebuddy.com

# Admin
ADMIN_EMAIL=you@example.com

# Feature flags
# ENABLE_BOT_UI: when "1", the Algo Bot product surfaces (nav link, /bot routes,
# Pro bot features). When "0" (default), the public site is the analyzer only
# and bot routes return 404. The bot continues to live on the `algo-bot` branch.
ENABLE_BOT_UI=0
