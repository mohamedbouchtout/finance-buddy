# Copy to .env and fill in. App runs in dev mode with empty values.

# Site
APP_BASE_URL=http://localhost:8000
APP_SECRET=change-me-to-a-long-random-string

# Stripe (TEST mode keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# Email (optional in dev — magic links print to console if blank)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=hello@financebuddy.com

# Admin
ADMIN_EMAIL=you@example.com
